#
#    "File Purpose:     Archivo de Exclusión de Git.-
#                       Define qué Archivos y Carpetas NO Deben Subirse al Repositorio: Entornos Virtuales,
#                       Archivos de Python Compilados, Carpetas de Backups y Documentación Local, Logs,
#                       Archivos de Configuración Sensibles ( .env, credentials.json ), y Archivos
#                       Temporales del Sistema Operativo.-
#
#
# *********************************************************************************************************************

# Virtual envs
.venv/
env/
venv/
ENV/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Backups y carpetas de usuario
..BUps/

# Documentación del Proyecto
..Documentación

# Comandos para GitHub
..GitHub_Comandos

# Build / packaging
build/
dist/
*.egg-info/
*.egg
.installed.cfg

# Tools / os
.DS_Store
.idea/
.vscode/

# Logs and runtime
logs/
*.log
*.sqlite3

# Secrets / local config
.env
credentials.json
sheets/credentials.json
*.pem

# Misc
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/


